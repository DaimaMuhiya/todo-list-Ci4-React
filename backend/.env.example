# Copiez vers `.env` pour le développement local.
#
# IMPORTANT — Render / Docker :
#   Le fichier `.env` n’est pas dans le dépôt Git : rien n’est copié dans le conteneur.
#   Recréez les MÊMES clés dans le tableau Render → Web Service → Environment
#   (les noms avec des points sont acceptés), par ex. :
#     database.default.hostname = ...
#     database.default.sslmode = require
#   Alternative : une seule variable DATABASE_URL (postgres://…) si votre hébergeur la fournit.

CI_ENVIRONMENT = production

app.baseURL = 'https://votre-service.onrender.com/'

# PostgreSQL (ex. Neon)
database.default.hostname = votre-hôte-pooler.region.provider.tech
database.default.database = neondb
database.default.username = neondb_owner
database.default.password = remplacer_par_secret
database.default.DBDriver = Postgre
database.default.DBPrefix =
database.default.port = 5432
database.default.schema = public
database.default.charset = utf8
# Obligatoire pour Neon et connexions distantes TLS depuis Render :
database.default.sslmode = require

encryption.key = hex2bin:votre_clé_ci4
